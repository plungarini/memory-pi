{
	"author": "",
	"dependencies": {
		"@fastify/static": "^8.0.0",
		"better-sqlite3": "^11.8.1",
		"dotenv": "^16.4.5",
		"fastify": "^5.0.0",
		"node-cron": "^3.0.3",
		"ollama": "^0.5.11",
		"sqlite-vec": "^0.1.6",
		"uuid": "^11.0.0",
		"zod": "^3.23.8"
	},
	"description": "Local vector memory backbone for the pi ecosystem",
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.12",
		"@types/node": "^22.0.0",
		"@types/node-cron": "^3.0.11",
		"@types/uuid": "^10.0.0",
		"concurrently": "^9.2.1",
		"eslint": "^9.0.0",
		"nodemon": "^3.1.0",
		"ts-node": "^10.9.2",
		"tsx": "^4.21.0",
		"typescript": "^5.4.5",
		"vitest": "^2.0.0",
		"wait-on": "^9.0.4"
	},
	"keywords": [
		"memory",
		"vector",
		"ai",
		"rag"
	],
	"license": "ISC",
	"main": "dist/index.js",
	"name": "memory-pi",
	"optionalDependencies": {
		"sqlite-vec-darwin-arm64": "0.1.6",
		"sqlite-vec-darwin-x64": "0.1.6",
		"sqlite-vec-linux-arm64": "0.1.6",
		"sqlite-vec-linux-x64": "0.1.6",
		"sqlite-vec-windows-x64": "0.1.6"
	},
	"scripts": {
		"build": "tsc && npm run build:ui",
		"build:ui": "cd ui && npm run build",
		"dev": "concurrently -k -p \"[{name}]\" -n \"OLLAMA,SERVER,UI\" -c \"blue,green,magenta\" \"node scripts/start-service.js ollama 11434 \\\"ollama serve\\\"\" \"npm run dev:server\" \"npm run dev:ui\"",
		"dev:server": "nodemon --watch src --ext ts,json --ignore dist --ignore ui --ignore data --ignore logs --exec npx tsx src/index.ts",
		"dev:ui": "cd ui && npm run dev",
		"lint": "eslint src/**/*.ts",
		"ollama": "node scripts/start-service.js ollama 11434 \"ollama serve\"",
		"onboard": "node scripts/onboard.js",
		"setup:vec": "node scripts/setup-vec.js",
		"start": "concurrently -k -p \"[{name}]\" -n \"OLLAMA,SERVER\" -c \"blue,green\" \"node scripts/start-service.js ollama 11434 \\\"ollama serve\\\"\" \"node dist/index.js\"",
		"start:dev": "npm run dev",
		"start:server": "node dist/index.js",
		"test": "vitest"
	},
	"type": "module",
	"version": "1.6.0"
}
