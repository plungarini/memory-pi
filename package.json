{
	"name": "memory-pi",
	"version": "1.0.0",
	"description": "Local vector memory backbone for the pi ecosystem",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"start": "node dist/index.js",
		"dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node --esm' src/index.ts",
		"build": "tsc && npm run build:ui",
		"build:ui": "cd ui && npm run build",
		"onboard": "node scripts/onboard.js",
		"test": "vitest",
		"lint": "eslint src/**/*.ts"
	},
	"keywords": [
		"memory",
		"vector",
		"ai",
		"rag"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@fastify/static": "^8.0.0",
		"chromadb": "^1.10.4",
		"dotenv": "^16.4.5",
		"fastify": "^5.0.0",
		"node-cron": "^3.0.3",
		"ollama": "^0.5.11",
		"uuid": "^11.0.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/node-cron": "^3.0.11",
		"@types/uuid": "^10.0.0",
		"eslint": "^9.0.0",
		"nodemon": "^3.1.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.4.5",
		"vitest": "^2.0.0"
	}
}
