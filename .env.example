# Server
PORT=3002
API_KEY=your_api_key_here

# Storage
BASE_STORAGE_PATH=./data
CHROMA_PATH=./data/chroma
# Use CHROMA_URL if utilizing a remote ChromaDB server or Docker
# CHROMA_URL=http://localhost:8000
PROMPT_PATH=./data/prompts

LOG_FALLBACK_PATH=./data/logs

# AI Services
OPENROUTER_API_KEY=your_openrouter_api_key_here
DISTILL_MODEL=google/gemini-2.0-flash-lite-001
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# Integration
LOGGER_PI_URL=http://localhost:4000
LOGGER_PI_SERVICE_NAME=memory-pi

# Limits & Logic
DISTILL_MAX_RETRIES=3
DISTILL_RETRY_DELAY_MS=1000
DISTILL_MAX_CHUNKS=10
DISTILL_MAX_CHUNK_CHARS=800
COLLECTION_STRATEGY=per-project
DEFAULT_SEARCH_LIMIT=5
MAX_SEARCH_LIMIT=50
DISK_WARN_THRESHOLD_GB=10
PROMPT_HOT_RELOAD=false
